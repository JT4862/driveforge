# Dev-mode state dir — created by `driveforge-daemon --dev --fixtures ...`
# and by scripts/capture-screenshots.py. Disposable; regenerated on every
# invocation. Don't commit the SQLite DB, seeded fixtures, or runtime
# paths.
/.driveforge-dev/

# Secrets (never commit)
.env
.env.*
!.env.example

# Build artefacts
/target/
/release/

# AI-session working notes. Useful across local Claude / Cursor sessions
# but internal enough that we don't want them distributed to OSS users.
# Files continue to exist locally; this just stops them from being tracked.
CLAUDE.md
AGENTS.md
.claude/
