[Unit]
Description=DriveForge TUI on tty1
After=driveforge-daemon.service getty@tty1.service
Wants=driveforge-daemon.service
Conflicts=getty@tty1.service

[Service]
Type=simple
User=driveforge
Group=driveforge
Environment=TERM=linux
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
StandardInput=tty
StandardOutput=tty
StandardError=tty
ExecStart=/usr/bin/driveforge-tui
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
